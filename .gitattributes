# Cross-platform (Linux + Windows) line-ending normalization.
# Repo stores LF; Windows checkout keeps LF for code, CRLF only where needed.
* text=auto eol=lf

# Windows-only scripts need CRLF
*.bat  text eol=crlf
*.ps1  text eol=crlf
*.cmd  text eol=crlf

# Binary assets — never touch line endings
*.png          binary
*.jpg          binary
*.safetensors  binary
*.bin          binary
*.db           binary
*.sqlite3      binary
