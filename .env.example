# ==========================================================
# PNB Workflow Agent — environment variable TEMPLATE
# ----------------------------------------------------------
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is git-ignored (holds real secrets); this template is committed.
# ==========================================================

# --- App ---
APP_ENV=development          # development | production

# --- LLM provider: OpenRouter (OpenAI-compatible gateway) ---
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model to route to (finalized when we build core/llm_client.py).
# OpenRouter format is "vendor/model", e.g. anthropic/claude-... or openai/gpt-...
LLM_MODEL=anthropic/claude-sonnet-5
